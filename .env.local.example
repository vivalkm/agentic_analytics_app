# Lakehouse Analytics — Environment Configuration
# Copy this file to .env.local and fill in your API key:
#   cp .env.local.example .env.local

# === LLM (required) ===
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://llm-gateway.dev.remitly.com/
ANTHROPIC_MODEL=anthropic.claude-opus-4-6-v1

# === Trino ===
TRINO_ENVIRONMENT=prod
TRINO_DEFAULT_CATALOG=lakehouse
TRINO_PRIORITY_SCHEMAS=fpa
TRINO_PRIORITY_TABLES=fpa.transaction_economics,fpa.treasury_margin_split
TRINO_SKIP_SCHEMAS=information_schema,sys,sandbox

# === Statsig ===
STATSIG_CONSOLE_API_KEY=
STATSIG_METRIC_TEAMS=squad-FPA,squad-INTA

# === GitHub Query Library ===
QUERY_LIBRARY_REPO=https://github.com/Remitly/fpa-bi/tree/main/src/main/resources/sql/trino/fpa
